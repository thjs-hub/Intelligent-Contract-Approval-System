# ============================================================
# 智能合同审查系统 - 环境配置模板
# 复制本文件为 .env 并修改对应值后重启服务
#   cp .env.example .env
#
# 加载优先级（由低到高）：
#   1. config.py 默认值
#   2. .env 文件值（本文件）
#   3. 操作系统环境变量（最高优先级，会覆盖以上两者）
# ============================================================

# === 应用配置 ===
APP_NAME=ContractReviewSystem
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# === 安全配置 ===
# JWT 签名密钥（生产环境务必替换为强随机字符串！）
SECRET_KEY=change-me-in-production
# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === 服务端口 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === API 配置 ===
API_V1_PREFIX=/api/v1

# === 数据库配置 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<your-mysql-password>
DB_NAME=contract_review
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# === Redis 配置 ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# === CORS 允许域名（开发环境） ===
CORS_ORIGINS=http://localhost:3000

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ===== 第二阶段配置 - 审批适配器 =====

# 审批系统适配器: mock / dingtalk / feishu / wecom
APPROVAL_ADAPTER=mock

# OCR 引擎类型: paddle / tesseract
OCR_ENGINE=paddle

# 文档解析提取器: regex / nlp
EXTRACTOR_TYPE=regex

# 评论回写最大重试次数
COMMENT_MAX_RETRY=3

# ===== 第三阶段配置 - AI 审查能力 =====

# --- LLM 智能审查 (P3-4) ---
LLM_ENABLED=false
# DeepSeek / 通义千问 / 智谱 / OpenAI 均支持，填写 OpenAI 兼容端点
LLM_ENDPOINT=https://api.deepseek.com
# 请填入你的 API Key（不要提交到版本控制）
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# --- 语义匹配 (P3-2) ---
# 启用前需安装: pip install sentence-transformers
SEMANTIC_ENABLED=false
SEMANTIC_THRESHOLD=0.75
SEMANTIC_MODEL=BAAI/bge-small-zh-v1.5

# --- OCR 布局分析 (P3-3) ---
# 启用前需安装: pip install paddleocr paddlepaddle
OCR_USE_LAYOUT=false
OCR_TABLE_RECOGNITION=false

# --- NLP 信息抽取 (P3-1) ---
# 启用前需安装: pip install hanlp 或 pip install spacy
NLP_EXTRACTOR_ENABLED=false
NLP_MODEL=hfl/chinese-roberta-wwm-ext

# --- AI 编排与报告 ---
AI_REVIEW_ENABLED=false
AI_REPORT_ENHANCE=false
