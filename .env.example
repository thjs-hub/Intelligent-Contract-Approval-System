# === 应用配置 ===
APP_NAME=ContractReviewSystem
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# === 服务端口 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === API 配置 ===
API_V1_PREFIX=/api/v1

# === 数据库配置 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=contract_review
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# === Redis 配置 ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# === CORS 允许域名（开发环境） ===
CORS_ORIGINS=http://localhost:3000

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
