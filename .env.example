# === 应用配置 ===
APP_NAME=ContractReviewSystem
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# === 服务端口 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === API 配置 ===
API_V1_PREFIX=/api/v1

# === 数据库配置 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=contract_review
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# === Redis 配置 ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# === CORS 允许域名（开发环境） ===
CORS_ORIGINS=http://localhost:3000

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ===== 第二阶段新增配置 =====

# 审批系统适配器: mock / dingtalk / feishu / wecom
# 第二阶段仅实现 mock，其余为第三阶段扩展点
APPROVAL_ADAPTER=mock

# OCR 引擎类型: paddle / tesseract
OCR_ENGINE=paddle

# 文档解析提取器: regex / nlp
# 第二阶段仅实现 regex，nlp 为第三阶段扩展点
EXTRACTOR_TYPE=regex

# 评论回写最大重试次数
COMMENT_MAX_RETRY=3

# ===== 第三阶段新增配置 — AI 审查能力 =====
# 所有 AI 能力默认关闭，可通过 .env 渐进式开启。
# 关闭时自动回退到第二阶段基础行为，不破坏端到端闭环。

# --- LLM 智能审查 (P3-4) ---
LLM_ENABLED=false
# OpenAI 兼容格式端点（通义千问/DeepSeek/智谱/OpenAI 均支持）
LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
# 请通过环境变量注入密钥，不要硬编码到此处
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT=60
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# --- 语义匹配 (P3-2) ---
# 启用前需安装: pip install sentence-transformers
SEMANTIC_ENABLED=false
SEMANTIC_THRESHOLD=0.75
SEMANTIC_MODEL=BAAI/bge-small-zh-v1.5

# --- OCR 布局分析 (P3-3) ---
# 启用前需安装: pip install paddleocr paddlepaddle
OCR_USE_LAYOUT=false
OCR_TABLE_RECOGNITION=false

# --- NLP 信息抽取 (P3-1) ---
# 启用前需安装: pip install hanlp 或 pip install spacy
NLP_EXTRACTOR_ENABLED=false
NLP_MODEL=hfl/chinese-roberta-wwm-ext

# --- AI 编排与报告 ---
AI_REVIEW_ENABLED=false
AI_REPORT_ENHANCE=false

# === 渐进式上线建议 ===
# 阶段 3A（无外部依赖）:
#   EXTRACTOR_TYPE=nlp + NLP_EXTRACTOR_ENABLED=true
#   OCR_USE_LAYOUT=true + OCR_TABLE_RECOGNITION=true
# 阶段 3B（需下载模型）:
#   SEMANTIC_ENABLED=true (首次运行自动下载 bge-small-zh-v1.5，约 100MB)
# 阶段 3C（需 LLM API 密钥）:
#   LLM_ENABLED=true + AI_REVIEW_ENABLED=true + AI_REPORT_ENHANCE=true
